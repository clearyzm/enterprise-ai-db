# =============================================================
# Enterprise AI Database — 环境变量示例
# 复制为 .env 后填入真实值，.env 已加入 .gitignore
# =============================================================

# -------------------------------------------------------------
# 数据库
# -------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/enterprise_ai
POSTGRES_DB=enterprise_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password-here

# -------------------------------------------------------------
# Redis
# -------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -------------------------------------------------------------
# JWT
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
# -------------------------------------------------------------
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# -------------------------------------------------------------
# 生成模型（D1 · 必须独立配置，不可与嵌入模型合并）
# LLM_MODEL        → classify / guardrail 等轻量节点
# LLM_STRONG_MODEL → synthesize 节点（最终回答），允许设成同一个模型
# -------------------------------------------------------------
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_STRONG_MODEL=gpt-4o

# -------------------------------------------------------------
# 嵌入模型（D1 · 独立配置，允许与生成模型用不同供应商）
# EMBED_API_KEY 留空 → 运行时自动 fallback 到 LLM_API_KEY
# ⚠️  换嵌入模型必须同步修改 EMBED_DIM，pgvector 列向量维度需匹配
# -------------------------------------------------------------
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# -------------------------------------------------------------
# 应用
# -------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1

# -------------------------------------------------------------
# Celery
# -------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# -------------------------------------------------------------
# 限流（slowapi，按 tenant_id + endpoint）
# -------------------------------------------------------------
RATE_LIMIT_DEFAULT=100/minute

# -------------------------------------------------------------
# 测试库（docker-compose.test.yml 使用，D4）
# -------------------------------------------------------------
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres_test@localhost:5433/enterprise_ai_test
# TEST_REDIS_URL=redis://localhost:6380/0
